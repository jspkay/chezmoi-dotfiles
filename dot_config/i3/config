set $mod+Control_l+l systemctl suspend

#
# Moving around:
#
      # Move your focus around (with hjkl)
      bindsym $mod+$left focus left
      bindsym $mod+$down focus down
      bindsym $mod+$up focus up
      bindsym $mod+$right focus right

      # focus to the next monitor 
      bindsym $mod+o focus output right

      # Move the focused window with the same, but add Shift (with hjkl)
      bindsym $mod+Shift+$left move left
      bindsym $mod+Shift+$down move down
      bindsym $mod+Shift+$up move up
      bindsym $mod+Shift+$right move right
      
#
# Workspaces:
#
      # Arrows move to the next workspace
      # bindsym $mod+Down workspace down
      # bindsym $mod+Up workspace up
      bindsym $mod+Left workspace prev
      bindsym $mod+Right workspace next

    bindsym $mod+Shift+Left move workspace to output left
    bindsym $mod+Shift+Down move workspace to output down
    bindsym $mod+Shift+Up move workspace to output up
    bindsym $mod+Shift+Right move workspace to output right
    
